{
    "name": "FAAST Plus",
    "version": "0.1.31",
    "description": "Improves amazon dropship's UI",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://dropship.amazon.com/*"
    ],
    "background": {
        "service_worker": "js/service-worker/index.js",
        "type": "module"
    },
    "options_ui": {
        "page": "html/options/index.html",
        "open_in_tab": true
    },
    "content_scripts": [
        {
            "matches": [
                "https://dropship.amazon.com/*"
            ],
            "css": [
                "css/extra/lazy.css"
            ]
        },
        {
            "matches": [
                "https://dropship.amazon.com/web/picktasks/new*"
            ],
            "js": [
                "js/content-scripts/new-order.js"
            ],
            "css": [
                "css/content-scripts/new-order.css"
            ]
        },
        {
            "matches": [
                "https://dropship.amazon.com/web/picktasks*"
            ],
            "js": [
                "js/content-scripts/ready-to-pick.js"
            ],
            "css": [
                "css/extra/tables.css",
                "css/content-scripts/ready-to-pick.css"
            ]
        },
        {
            "matches": [
                "https://dropship.amazon.com/web/picktasks/print*"
            ],
            "js": [
                "js/content-scripts/pickTask-print.js"
            ]
        },
        {
            "matches": [
                "https://dropship.amazon.com/mobile/pack/printDocumentsForBulk?printServerName=*"
            ],
            "js": [
                "js/content-scripts/quickPack.js"
            ], 
            "css": [
                "css/extra/buttons.css"
            ]
        },
        {
            "matches": [
                "https://dropship.amazon.com/web/pack/packBulk/picktask*"
            ],
            "js": [
                "js/content-scripts/single-order-scan.js"
            ], 
            "css": [
                "css/extra/tables.css",
                "css/extra/buttons.css"
            ]
        },
        {
            "matches": [
                "https://dropship.amazon.com/web/picktasks?selectedStatus=ALL&selectedTimeFrame=ALL&pageSize=1000*"
            ],
            "js": [
                "js/content-scripts/past-productivity-report.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "matches": [
                "https://dropship.amazon.com/*"
            ],
            "resources": [
                "js/utils/utils.js"
            ]
        }
    ],
    "action": {
        "default_icon": {
            "16": "assets/images/faastPlus-icon.png",
            "24": "assets/images/faastPlus-icon.png",
            "32": "assets/images/faastPlus-icon.png"
        },
        "default_title": "FAAST Plus",
        "default_popup": "html/popup/index.html"
    },
    "icons": {
        "16": "assets/images/faastPlus-icon.png",
        "32": "assets/images/faastPlus-icon.png",
        "48": "assets/images/faastPlus-icon.png",
        "128": "assets/images/faastPlus-icon.png"
    },
    "manifest_version": 3
}